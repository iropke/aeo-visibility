# ============================================================
# AEO Visibility Backend Configuration
# .env 파일 템플릿 — 실제 값을 넣어서 .env로 복사하세요
# cp .env.template .env
# ============================================================

# ─── STEP 1: SUPABASE (필수) ───
# Supabase 콘솔 → Settings → Configuration/API에서 복사
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR_DB_PASSWORD]@[YOUR_PROJECT_REF].supabase.co:5432/postgres
SUPABASE_URL=https://[YOUR_PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=[YOUR_SUPABASE_ANON_KEY]
SUPABASE_SERVICE_ROLE_KEY=[YOUR_SUPABASE_SERVICE_ROLE_KEY]

# ─── STEP 2: UPSTASH (필수 — 캐싱용) ───
# Upstash 콘솔 → Databases → 연결 문자열 복사
REDIS_URL=rediss://default:[YOUR_UPSTASH_PASSWORD]@[YOUR_ENDPOINT].upstash.io:6379

# ─── STEP 3: CLAUDE API (필수) ───
# Claude API 키 (console.anthropic.com → API Keys)
CLAUDE_API_KEY=sk-ant-api03-[YOUR_CLAUDE_API_KEY]

# ─── STEP 4: OPENAI API (선택) ───
# OpenAI API 키 (platform.openai.com → API Keys)
OPENAI_API_KEY=sk-proj-[YOUR_API_KEY]

# ─── STEP 5: RESEND (이메일 발송, 선택) ───
# Resend 콘솔 → API Keys에서 복사
RESEND_API_KEY=re_[YOUR_RESEND_API_KEY]

# ─── FRONTEND ───
# Vercel 배포 후 본인의 도메인으로 변경
FRONTEND_URL=https://aeo-visibility.vercel.app
CORS_ORIGINS=https://aeo-visibility.vercel.app,http://localhost:3000

# ─── ENVIRONMENT ───
ENV=production
LOG_LEVEL=info

# ─── TIMEOUT & CACHE ───
ANALYSIS_TIMEOUT_SECONDS=30
CACHE_TTL_DAYS=7

# ─── 로컬 개발용 (선택) ───
# 로컬에서 테스트할 때만 사용
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/aeo
# REDIS_URL=redis://localhost:6379/0
# ENV=development
# FRONTEND_URL=http://localhost:3000
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
